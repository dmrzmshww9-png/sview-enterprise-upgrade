<script>
    // 倒计时：截止2026年3月31日 23:59:59
    function getEndTime() {
        // 设定活动截止日期: 2026年3月31日 23:59:59
        return new Date(2026, 2, 31, 23, 59, 59); // 月份从0开始，2表示三月
    }

    function updateCountdown() {
        const endDate = getEndTime();
        const now = new Date();
        const diff = endDate - now;

        if (diff <= 0) {
            document.getElementById('countdownTimer').innerHTML = '活动已结束';
            return;
        }

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        const formatted = `${days}天 ${hours.toString().padStart(2,'0')}:${minutes.toString().padStart(2,'0')}:${seconds.toString().padStart(2,'0')}`;
        document.getElementById('countdownTimer').innerHTML = formatted;
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);

    // 可选: 增强按钮点击行为追踪(保持链接跳转即可)
    // 所有外部链接 https://sview3d.com/ 正常跳转
</script>
